<UserControl x:Class="WfcLand.Controls.DropdownLabel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WfcLand.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid Margin="14 0 0 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding LabelWidth, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0"
                   VerticalAlignment="Center"
                   Content="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            <ComboBox Grid.Column="1"
                      HorizontalAlignment="Stretch"
                      ItemsSource="{Binding ItemsSource,RelativeSource={RelativeSource AncestorType=UserControl}}"
                      SelectedValue="{Binding SelectedValue, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      VerticalAlignment="Center"
                      DisplayMemberPath="Name"
                      IsEnabled="{Binding IsEnabled,RelativeSource={RelativeSource AncestorType=UserControl}}"
                      SelectedValuePath="Id" />
        </Grid>
    </Grid>
</UserControl>

    
    