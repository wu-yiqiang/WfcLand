<Page x:Class="WfcLand.Views.Setting"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      xmlns:local="clr-namespace:WfcLand.Views"
      xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
      mc:Ignorable="d"
      d:DesignHeight="450"
      d:DesignWidth="800"
      Title="Setting">
    <ikw:SimpleStackPanel Spacing="4">
        <ui:SettingsCard x:Name="settingsCard"
                         Header="应用主题"
                         IsEnabled="True">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Glyph="&#xE790;" />
            </ui:SettingsCard.HeaderIcon>
            <ComboBox SelectedIndex="0">
                <ComboBoxItem>跟随系统</ComboBoxItem>
                <ComboBoxItem>深色</ComboBoxItem>
                <ComboBoxItem>浅色</ComboBoxItem>
            </ComboBox>
        </ui:SettingsCard>
        <ui:SettingsCard Header="界面语言"
                         IsEnabled="True">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Glyph="&#xF2B7;" />
            </ui:SettingsCard.HeaderIcon>
            <ComboBox SelectedIndex="0">
                <ComboBoxItem>简体中文</ComboBoxItem>
                <ComboBoxItem>English</ComboBoxItem>
            </ComboBox>
        </ui:SettingsCard>
        <ui:SettingsExpander Description="© WfcLand 2026. All rights reserved."
                             Header="WfcLand">
            <ui:SettingsExpander.HeaderIcon>
                <Image Source="/Assets/logo.png"
                       Width="40"
                       Height="40"
                       RenderOptions.BitmapScalingMode="HighQuality" />
            </ui:SettingsExpander.HeaderIcon>
            <TextBlock Foreground="{DynamicResource {x:Static ui:ThemeKeys.TextFillColorSecondaryBrushKey}}"
                       Text="0.0.1" />
            <ui:SettingsExpander.Items>
                <ui:SettingsCard HorizontalContentAlignment="Left"
                                 ContentAlignment="Left">
                    <StackPanel Margin="-12,0,0,0"
                                Orientation="Horizontal">
                        <ui:HyperlinkButton Content="源代码"
                                            NavigateUri="https://github.com/wu-yiqiang/WfcLand" />
                        <ui:HyperlinkButton Content="隐私政策"
                                            Click="HandlePrivacyDialog"
                                            RaiseHyperlinkClicks="False" />
                        <ui:HyperlinkButton Content="许可证"
                                            Click="HandleLicenseDialog"
                                            RaiseHyperlinkClicks="False" />
                        <ui:HyperlinkButton Content="报告问题"
                                            NavigateUri="https://github.com/wu-yiqiang/WfcLand/issues" />
                    </StackPanel>
                </ui:SettingsCard>
            </ui:SettingsExpander.Items>
        </ui:SettingsExpander>
        <ui:ContentDialog x:Name="PrivacyDialog"
                          Title="隐私政策"
                          Width="220"
                          SecondaryButtonText="关闭">
            <StackPanel>
                <TextBlock Text="  This Privacy Policy describes Our policies and procedures on the collection, use and disclosure of Your information when You use the Service and tells You about Your privacy rights and how the law protects You. We use Your anonynous Non-Personal data and health and performance data of the Service to provide and improve the Service itself. By using the Service, You agree to the collection and use of information in accordance with this Privacy Policy." />
                
            </StackPanel>
        </ui:ContentDialog>
        <ui:ContentDialog x:Name="LicenseDialog"
                          Title="许可证"
                          MaxWidth="420"
                          SecondaryButtonText="关闭">
            <StackPanel>
                <TextBlock Text="MIT License
Copyright (c) 2021 Etienne Baudoux" />
            </StackPanel>
        </ui:ContentDialog>
    </ikw:SimpleStackPanel>
    
</Page>
