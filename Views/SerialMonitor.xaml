<Page x:Class="WfcLand.Views.SerialMonitor"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      xmlns:local="clr-namespace:WfcLand.Views"
      xmlns:local1="clr-namespace:WfcLand.Controls"
      mc:Ignorable="d">
    <Grid >
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>
            <DockPanel Grid.Column="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="150" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition Height="50" />
                        </Grid.RowDefinitions>
                        <TextBox Text="{Binding ReceiveText, Mode=OneWay}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 IsReadOnly="True" />
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition  Width="120" />
                                <ColumnDefinition  Width="120" />
                                <ColumnDefinition />
                                <ColumnDefinition  Width="60" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      Content="显示时间戳"
                                      IsChecked="{Binding ShowTimeStamp}" />
                            <CheckBox Grid.Column="1"
                                      Content="自动滚动"
                                      IsChecked="{Binding AutoScroll}" />
                            <local1:DropdownLabel Grid.Column="2"
                                                  Label="编码模式"
                                                  LabelWidth="70"
                                                  ItemsSource="{Binding EncodeModeOptions}"
                                                  SelectedValue="{Binding SelectedReciveEncodeId}" />
                            <Button HorizontalAlignment="Right"
                                    Grid.Column="4"
                                    Command="{Binding ReceiveClear}"
                                    Content="清空" />
                        </Grid>
                    </Grid>
                    <Grid Grid.Row="1"
                          >
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition Height="32" />
                        </Grid.RowDefinitions>
                        <TextBox Text="{Binding SendText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 Margin="0 0 0 10" />
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition />
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="60" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      Content="自动发送"
                                      IsChecked="{Binding AutoSend}" />
                            <Label Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Content="发送周期(ms)" />
                            <TextBox Grid.Column="2"
                                     AcceptsReturn="True"
                                     Text="{Binding SendFrequency, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <local1:DropdownLabel Grid.Column="3"
                                                  Label="编码"
                                                  LabelWidth="40"
                                                  ItemsSource="{Binding EncodeModeOptions}"
                                                  SelectedValue="{Binding SelectedReciveEncodeId}" />
                            <Button Grid.Column="4"
                                    HorizontalAlignment="Right"
                                    Grid.Row="0"
                                    Content="发送"
                                    IsEnabled="{Binding OpenSerial}"
                                    Style="{DynamicResource AccentButtonStyle}"
                                    Command="{Binding SendCommand}" />
                            <Button Grid.Column="5"
                                    HorizontalAlignment="Right"
                                    Grid.Row="1"
                                    Content="清空"
                                    Command="{Binding SendClear}" />
                        </Grid>
                    </Grid>
                </Grid>
            </DockPanel>
            <DockPanel  Grid.Column="1"
                        VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="60"   />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="50" />
                            <RowDefinition Height="50" />
                            <RowDefinition Height="50" />
                            <RowDefinition Height="50" />
                            <RowDefinition Height="50" />
                            <RowDefinition Height="50" />
                            <RowDefinition Height="50" />
                            <RowDefinition Height="50" />
                        </Grid.RowDefinitions>
                        <local1:DropdownLabel  Grid.Row="0"
                                               Label="串口号"
                                               ItemsSource="{Binding SerialList}"
                                               IsEnabled="{Binding Enabled}"
                                               SelectedValue="{Binding SerialName}" />
                        <local1:DropdownLabel  Grid.Row="1"
                                               Label="波特率"
                                               ItemsSource="{Binding BaudRateOptions}"
                                               IsEnabled="{Binding Enabled}"
                                               SelectedValue="{Binding BaudRate}" />
                        <local1:DropdownLabel  Grid.Row="2"
                                               Label="校验位"
                                               ItemsSource="{Binding BaudParityBitOptions}"
                                               IsEnabled="{Binding Enabled}"
                                               SelectedValue="{Binding SelectedParityBitId}" />
                        <local1:DropdownLabel  Grid.Row="3"
                                               Label="数据位"
                                               ItemsSource="{Binding BaudDataBitOptions}"
                                               IsEnabled="{Binding Enabled}"
                                               SelectedValue="{Binding SelectedDataBitId}" />
                        <local1:DropdownLabel  Grid.Row="4"
                                               Label="停止位"
                                               IsEnabled="{Binding Enabled}"
                                               ItemsSource="{Binding BaudStopBitOptions}"
                                               SelectedValue="{Binding SelectedStopBitId}" />
                    </Grid>
                    <Button VerticalAlignment="Bottom" Grid.Row="1"
                            Margin="16 0 0 0"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{Binding ButtonEnabled}"
                            Command="{Binding BtnOpenCommand}">
                        <Button.Style>
                            <Style TargetType="Button"
                                   BasedOn="{StaticResource AccentButtonStyle}">
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center">
                                            <Image Source="pack://application:,,,/Wfcland;component/Assets/Icons/launch.png"
                                                   Width="20"
                                                   Height="20"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center" />
                                            <TextBlock Text="连接串口"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Background"
                                        Value="{DynamicResource SystemControlBackgroundAccentBrush}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource SystemControlForegroundChromeWhiteBrush}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4"
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter x:Name="contentPresenter"
                                                                  Focusable="False"
                                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                  Margin="{TemplateBinding Padding}"
                                                                  RecognizesAccessKey="True"
                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver"
                                                         Value="True">
                                                    <Setter TargetName="border"
                                                            Property="Opacity"
                                                            Value="0.9" />
                                                </Trigger>
                                                <Trigger Property="IsPressed"
                                                         Value="True">
                                                    <Setter TargetName="border"
                                                            Property="Opacity"
                                                            Value="0.8" />
                                                </Trigger>
                                                <Trigger Property="IsEnabled"
                                                         Value="False">
                                                    <Setter TargetName="border"
                                                            Property="Opacity"
                                                            Value="0.5" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding OpenSerial}"
                                                 Value="True">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Center">
                                                    <Image Source="pack://application:,,,/Wfcland;component/Assets/Icons/stop.png"
                                                           Width="20"
                                                           Height="20"
                                                           Margin="0,0,8,0"
                                                           VerticalAlignment="Center" />
                                                    <TextBlock Text="关闭串口"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Background"
                                                Value="#28a745" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </DockPanel>
        </Grid>
    </Grid>
</Page>
